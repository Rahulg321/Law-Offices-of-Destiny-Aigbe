{
  "compilerOptions": {
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "components/**/*.ts",
    "components/**/*.tsx",
    "slices/**/*.ts",
    "slices/**/*.tsx",
    "lib/**/*.ts",
    "lib/**/*.tsx",
    "router.tsx",
    "prismicio.ts",
    "prismicio-types.d.ts",
    "vite-env.d.ts"
  ],
  "exclude": ["node_modules", ".output", "vite.config.ts"]
}
